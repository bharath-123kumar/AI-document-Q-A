# ─────────────────────────────────────────────────────────────
# RAG Document Q&A Bot — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to git.
# ─────────────────────────────────────────────────────────────

# Google Gemini API Key (get one free at https://aistudio.google.com/)
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional Overrides ────────────────────────────────────────
# Number of chunks to retrieve per query (default: 5)
TOP_K=5

# ChromaDB persistence directory (default: ./chroma_db)
CHROMA_DB_PATH=./chroma_db

# Documents folder (default: ./data)
DATA_PATH=./data

# Gemini model to use (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
